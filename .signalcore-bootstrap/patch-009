+class ContextKnapsackV2:
+    def __init__(self, token_weight: float = 1.0, transfer_weight: float = 0.25, latency_weight: float = 0.05) -> None:
+        self.token_weight = token_weight
+        self.transfer_weight = transfer_weight
+        self.latency_weight = latency_weight
+
+    def utility(self, item: EvidenceRecord) -> float:
+        numerator = (
+            2.2 * item.task_relevance
+            + 1.9 * item.failure_impact
+            + 1.3 * item.freshness
+            + 1.2 * item.confidence
+            + 1.2 * item.dependency_importance
+            + 1.7 * item.security_relevance
+            + 0.9 * item.visual_relevance
+            + 0.6 * item.reuse_probability
+        )
+        denominator = max(
+            1.0,
+            self.token_weight * item.estimated_token_cost
+            + self.transfer_weight * item.estimated_transfer_cost
+            + self.latency_weight * item.estimated_transfer_cost,
+        )
+        return numerator / denominator
+
+    def select(
+        self,
+        candidates: Sequence[EvidenceRecord],
+        *,
+        token_budget: int,
+        transfer_budget: int,
+        required_types: Iterable[str] = (),
+    ) -> tuple[EvidenceRecord, ...]:
+        if token_budget <= 0 or transfer_budget < 0:
+            raise ValueError("invalid context budget")
+        required = tuple(dict.fromkeys(map(str, required_types)))
+        selected: list[EvidenceRecord] = []
+        used_tokens = 0
+        used_transfer = 0
+        by_type: dict[str, list[EvidenceRecord]] = {}
+        for item in candidates:
+            by_type.setdefault(item.evidence_type, []).append(item)
+        for evidence_type in required:
+            options = sorted(by_type.get(evidence_type, ()), key=lambda item: (-self.utility(item), item.evidence_id))
+            if not options:
+                continue
+            item = options[0]
+            if used_tokens + item.estimated_token_cost <= token_budget and used_transfer + item.estimated_transfer_cost <= transfer_budget:
+                selected.append(item)
+                used_tokens += item.estimated_token_cost
+                used_transfer += item.estimated_transfer_cost
+        ranked = sorted(candidates, key=lambda item: (-self.utility(item), -item.freshness, item.evidence_id))
+        seen = {item.evidence_id for item in selected}
+        sources: dict[tuple[str, str], str] = {(item.source_path, item.source_hash): item.evidence_id for item in selected}
+        for item in ranked:
+            if item.evidence_id in seen:
+                continue
+            source_key = (item.source_path, item.source_hash)
+            if source_key in sources:
+                continue
+            if used_tokens + item.estimated_token_cost > token_budget:
+                continue
+            if used_transfer + item.estimated_transfer_cost > transfer_budget:
+                continue
+            selected.append(item)
+            seen.add(item.evidence_id)
+            sources[source_key] = item.evidence_id
+            used_tokens += item.estimated_token_cost
+            used_transfer += item.estimated_transfer_cost
+        return tuple(selected)
+
+    def capsule(
+        self,
+        task: RobloxTaskState,
+        candidates: Sequence[EvidenceRecord],
+        *,
+        token_budget: int,
+        transfer_budget: int,
+        tools: Iterable[str],
+        project_summary: Mapping[str, object] | None = None,
+        recipes: Iterable[str] = (),
+        api_facts: Iterable[str] = (),
+    ) -> ContextCapsule:
+        selected = self.select(
+            candidates,
+            token_budget=token_budget,
+            transfer_budget=transfer_budget,
+            required_types=task.required_evidence,
+        )
+        return ContextCapsule(
+            task=task.to_dict(),
+            project_summary=dict(project_summary or {}),
+            evidence=selected,
+            recipes=tuple(dict.fromkeys(map(str, recipes))),
+            api_facts=tuple(dict.fromkeys(map(str, api_facts))),
+            acceptance_criteria=task.acceptance_criteria,
+            tool_definitions=tuple(dict.fromkeys(map(str, tools))),
+            total_tokens=sum(item.estimated_token_cost for item in selected),
+            total_transfer_cost=sum(item.estimated_transfer_cost for item in selected),
+        )
