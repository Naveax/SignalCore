+    security_class: str = "PROJECT_CONTENT",
+    token_cost: int = 0,
+    transfer_cost: int = 0,
+    **metrics: float,
+) -> EvidenceRecord:
+    data = content.encode("utf-8") if isinstance(content, str) else content
+    source_hash = hashlib.sha256(data).hexdigest()
+    evidence_id = hashlib.sha256(f"{evidence_type}\0{source_path}\0{source_hash}".encode()).hexdigest()[:32]
+    return EvidenceRecord(
+        evidence_id=evidence_id,
+        evidence_type=evidence_type,
+        source=source,
+        source_path=source_path,
+        source_hash=source_hash,
+        dependency_hashes=tuple(sorted(map(str, dependency_hashes))),
+        created_at=time.time(),
