+class MultimodalEvidenceManager:
+    def __init__(self, maximum_frames: int = 6, near_duplicate_distance: int = 4) -> None:
+        self.maximum_frames = maximum_frames
+        self.near_duplicate_distance = near_duplicate_distance
+
+    @staticmethod
+    def perceptual_fingerprint(payload: bytes) -> int:
+        digest = hashlib.sha256(payload).digest()[:8]
+        return int.from_bytes(digest, "big")
+
+    @staticmethod
+    def distance(left: int, right: int) -> int:
+        return (left ^ right).bit_count()
+
+    def select_frames(
+        self,
+        frames: Sequence[tuple[str, bytes, float, bool]],
+        *,
+        technical_metrics_sufficient: bool,
+        visual_judgment_required: bool,
+    ) -> tuple[str, ...]:
+        if technical_metrics_sufficient and not visual_judgment_required:
+            return ()
+        chosen: list[tuple[str, int, float, bool]] = []
+        for frame_id, payload, importance, failure_frame in sorted(frames, key=lambda row: (-int(row[3]), -row[2], row[0])):
+            fingerprint = self.perceptual_fingerprint(payload)
+            if any(self.distance(fingerprint, existing[1]) <= self.near_duplicate_distance for existing in chosen):
+                continue
+            chosen.append((frame_id, fingerprint, importance, failure_frame))
+            if len(chosen) >= self.maximum_frames:
+                break
+        return tuple(item[0] for item in chosen)
+
