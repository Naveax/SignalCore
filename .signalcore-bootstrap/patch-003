+def _route_bucket(model_id: str, deterministic: bool) -> str:
+    if deterministic:
+        return "DETERMINISTIC"
+    if model_id in {"micro-local", "worker-local", "vision-local"}:
+        return "LOCAL"
+    if model_id == "cloud-lite":
+        return "CLOUD_LITE"
+    if model_id == "cloud-expert":
+        return "CLOUD_EXPERT"
+    return "BLOCKED"
+
