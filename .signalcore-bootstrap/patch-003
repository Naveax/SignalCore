+def _seed_evidence(ledger: EvidenceLedger) -> None:
+    types = (
+        "PROJECT_INSTANCE", "PROJECT_SCRIPT", "SCRIPT_INTERFACE", "REQUIRE_GRAPH", "ASSET_METADATA",
+        "ASSET_SECURITY_REPORT", "RIG_MAPPING", "ANIMATION_METRICS", "IMAGE_PREVIEW", "VIDEO_PREVIEW",
+        "MIGRATION_RESULT", "USER_APPROVAL",
+    )
+    for index, evidence_type in enumerate(types):
+        ledger.put(make_evidence(
+            evidence_type=evidence_type,
+            source="benchmark",
+            source_path=f"benchmark/{evidence_type}.json",
+            content=f"{evidence_type} current verified evidence",
+            payload_reference=f"memory://{evidence_type}",
+            summary_reference=f"summary://{evidence_type}",
+            token_cost=40 + index * 3,
+            transfer_cost=10,
+            task_relevance=.9,
+            failure_impact=.8,
+            dependency_importance=.7,
+            security_relevance=.9 if "SECURITY" in evidence_type or "MIGRATION" in evidence_type else .2,
+            visual_relevance=.9 if evidence_type in {"IMAGE_PREVIEW", "VIDEO_PREVIEW"} else .1,
+            reuse_probability=.9,
+        ))
+
