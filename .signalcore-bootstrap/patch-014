se "test"
+    if values & {"instance_deletion"}:
+        return "delete"
+    if values & {"instance_creation", "script_creation", "ui_creation", "animation_generation", "world_building", "terrain_generation", "procedural_structure"}:
+        return "create"
+    return "modify"
+
+
+def _risk(task_classes: Iterable[str], operation: str) -> RiskLevel:
+    values = set(task_classes)
+    if "datastore_migration" in values:
+        return RiskLevel.R5
+    if values & {"security_review", "blender_job"}:
+        return RiskLevel.R4
+    if operation == "delete" or values & {"combat_choreography", "cinematic_creation", "digital_twin_execution", "release_validation", "asset_import", "world_building"}:
+        return RiskLevel.R3
+    if operation in {"create", "modify"} or values & {"runtime_debugging", "performance_review"}:
+        return RiskLevel.R2
+    if operation in {"test", "search"}:
+        return RiskLevel.R1
+    return RiskLevel.R0
+
+
+def _sandbox(task_classes: Iterable[str], risk: RiskLevel) -> SandboxLevel:
+    values = set(task_classes)
+    if "datastore_migration" in values:
+        return SandboxLevel.MIGRATION_LAB
+    if "blender_job" in values:
+        return SandboxLevel.EXTERNAL_SANDBOX
+    if values & {"digital_twin_execution", "combat_choreography", "cinematic_creation", "security_review", "multi_device_validation", "release_validation"}:
+        return SandboxLevel.DIGITAL_TWIN
+    if risk in {RiskLevel.R3, RiskLevel.R4, RiskLevel.R5}:
+        return SandboxLevel.SHADOW_PROJECT
+    if risk == RiskLevel.R2:
+        return SandboxLevel.PREVIEW
+    return SandboxLevel.NONE
+
+
+def classify_deterministic_task(text: str, *, selected_instances: Iterable[str] = ()) -> bool:
+    selected = tuple(selected_instances)
+    return bool(selected) and any(pattern.search(text) for pattern in DETERMINISTIC_PATTERNS)
+
+
+def validate_deterministic_parameters(text: str, *, selected_instances: Iterable[str] = ()) -> tuple[bool, tuple[str, ...]]:
+    reasons: list[str] = []
+    if not tuple(selected_instances):
+        reasons.append("selected instance is required")
+    if not NUMERIC.search(text) and not re.search(r"\b(?:Metal|Plastic|Neon|true|false|red|blue|green)\b", text, re.I):
+        reasons.append("deterministic value is missing")
+    if AMBIGUOUS_REFERENCES.search(text) and not TARGET_HINTS.search(text) and not tuple(selected_instances):
+        reasons.append("target reference is ambiguous")
+    return not reasons, tuple(reasons)
+
+
+def encode_task(
+    objective: str,
+    *,
+    session_id: str,
+    project_id: str,
+    selected_instances: Iterable[str] = (),
+    resolved_targets: Iterable[str] = (),
+    reference_instances: Iterable[str] = (),
+    constraints: Mapping[str, Any] | None = None,
+    acceptance_criteria: Iterable[str] = (),
+) -> RobloxTaskState:
+    task_classes = _task_classes(objective)
+    operation = _operation(task_classes, objective)
+    selected = tuple(dict.fromkeys(map(str, selected_instances)))
+    resolved = tuple(dict.fromkeys(map(str, resolved_targets)))
+    references = tuple(dict.fromkeys(map(str, reference_instances)))
+    capabilities = tuple(dict.fromkeys(cap for task in task_classes for cap in CAPABILITIES_BY_TASK.get(task, ("ROBLOX_PROJECT_READ",))))
+    risk = _risk(task_classes, operation)
+    sandbox = _sandbox(task_classes, risk)
+    deterministic = classify_deterministic_task(objective, selected_instances=selected)
+    ambiguities: list[str] = []
+    if operation in {"create", "modify", "delete", "debug", "test"} and not (selected or resolved):
+        if AMBIGUOUS_REFERENCES.search(objective) or not TARGET_HINTS.search(objective):
+            ambiguities.append("target_unresolved")
+    if "spatial_placement" in task_classes and not (references or NUMERIC.search(objective)):
+        ambiguities.append("spatial_reference_unresolved")
+    if task_classes == ("animation_repair",) and not acceptance_criteria:
+        ambiguities.append("animation_success_criteria_missing")
+    execution_allowed = deterministic and not ambiguities
+    cloud_need = "NONE" if deterministic else "REQUIRED" if risk in {RiskLevel.R4, RiskLevel.R5} else "LIKELY" if risk == RiskLevel.R3 else "UNLIKELY"
+    complexity = min(1.0, 0.08 * len(task_classes) + 0.04 * len(capabilities) + 0.12 * int(risk.value[1:]))
+    digest = hashlib.sha256((objective.strip() + "\0" + project_id + "\0" + session_id).encode("utf-8")).hexdigest()[:24]
+    return RobloxTaskState(
+        domain="roblox_studio",
+        task_id=f"rbx-{digest}",
+        session_id=session_id,
+        project_id=project_id,
+        user_objective=objective.strip(),
+        task_classes=task_classes,
+        operation_class=operation,
+        execution_mode="DETERMINISTIC" if deterministic else "ORCHESTRATED",
+        selected_instances=selected,
+        resolved_targets=resolved,
+        reference_instances=references,
+        required_capabilities=capabilities,
+        constraints=dict(constraints or {}),
+        acceptance_criteria=tuple(dict.fromkeys(map(str, acceptance_criteria))),
+        required_evidence=tuple(dict.fromkeys(_required_evidence(task_classes))),
+        ambiguities=tuple(dict.fromkeys(ambiguities)),
+        risk_level=risk,
+        sandbox_level=sandbox,
+        estimated_complexity=complexity,
+        estimated_cloud_need=cloud_need,
+        execution_allowed=execution_allowed,
+    )
+
+
+def _required_evidence(task_classes: Iterable[str]) -> list[str]:
+    output = ["PROJECT_INSTANCE"]
+    values = set(task_classes)
+    if any(item.startswith("script_") for item in values) or values & {"gameplay_system", "runtime_debugging", "security_review"}:
+        output.extend(("PROJECT_SCRIPT", "SCRIPT_INTERFACE", "REQUIRE_GRAPH"))
+    if values & {"creator_store_search", "asset_selection", "asset_import", "asset_sanitization", "asset_adaptation"}:
+        output.extend(("ASSET_METADATA", "ASSET_SECURITY_REPORT"))
+    if values & {"animation_generation", "animation_retargeting", "animation_repair", "custom_rig_mapping", "creature_animation", "facial_animation", "combat_choreography"}:
+        output.extend(("RIG_MAPPING", "ANIMATION_METRICS"))
+    if values & {"cinematic_creation", "ui_validation", "multi_device_validation"}:
+        output.extend(("IMAGE_PREVIEW", "VIDEO_PREVIEW"))
+    if "datastore_migration" in values:
+        output.extend(("MIGRATION_RESULT", "USER_APPROVAL"))
+    return output
+
