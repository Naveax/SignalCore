+def understanding_gate(
+    task: RobloxTaskState,
+    *,
+    capabilities_available: bool,
+    engines_available: bool,
+    evidence_available: bool,
+    model_certified: bool,
+    sandbox_available: bool,
+    budget_available: bool = True,
+) -> GateDecision:
+    reasons: list[str] = []
+    if task.ambiguities:
+        return GateDecision(GateStatus.BLOCKED_AMBIGUOUS, task.ambiguities, False)
+    if not capabilities_available:
+        return GateDecision(GateStatus.BLOCKED_UNSUPPORTED, ("required capability is unavailable",), False)
+    if not engines_available:
+        return GateDecision(GateStatus.BLOCKED_MISSING_ENGINE, ("certified engine is unavailable",), False)
+    if not evidence_available:
+        return GateDecision(GateStatus.BLOCKED_MISSING_EVIDENCE, ("required evidence is unavailable",), False)
+    if not sandbox_available or not model_certified:
+        reasons.append("risk/certification policy requires review")
+        return GateDecision(GateStatus.BLOCKED_POLICY, tuple(reasons), False)
+    if not budget_available:
+        return GateDecision(GateStatus.BLOCKED_BUDGET, ("task budget is exhausted",), False)
+    if task.risk_level in {RiskLevel.R3, RiskLevel.R4, RiskLevel.R5}:
+        return GateDecision(GateStatus.SUPPORTED_WITH_REVIEW, ("human approval required",), True)
+    return GateDecision(GateStatus.SUPPORTED, (), True)
+
+
+def with_execution(task: RobloxTaskState, allowed: bool) -> RobloxTaskState:
+    return replace(task, execution_allowed=allowed)
