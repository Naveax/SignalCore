+    "STATIC_VALIDATION": ("run_static_validation",),
+    "RUNTIME_PLAYTEST": ("run_playtest", "collect_runtime_errors"),
+    "MULTIPLAYER_PLAYTEST": ("run_multiplayer_playtest",),
+    "CREATOR_STORE_SEARCH": ("search_creator_store", "inspect_asset_metadata"),
+    "ASSET_SANITIZATION": ("scan_asset", "validate_geometry"),
+    "ASSET_IMPORT": ("import_asset_preview", "commit_asset", "rollback"),
+    "SPATIAL_SOLVER": ("place_relative", "validate_overlap", "preview_change"),
