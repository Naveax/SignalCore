+
+
+@dataclass(frozen=True)
+class RoutingContext:
+    cloud_requests_used: int = 0
+    cloud_tokens_used: int = 0
+    local_tokens_used: int = 0
+    gpu_time_used_ms: int = 0
+    cache_hit_rate: float = 0.0
+    repair_probability: float = 0.0
+    user_quality_mode: str = "BALANCED"
+
+
+def dynamic_tools(capabilities: Iterable[str], risk: RiskLevel) -> tuple[str, ...]:
+    tools = list(dict.fromkeys(tool for capability in capabilities for tool in TOOLS_BY_CAPABILITY.get(capability, ())))
+    if risk in {RiskLevel.R3, RiskLevel.R4, RiskLevel.R5}:
+        tools = [tool for tool in tools if tool not in {"commit_change", "commit_asset"}]
+        tools.extend(("request_human_approval", "preview_change", "rollback"))
+    return tuple(dict.fromkeys(tools))
+
+
+def deterministic_workflow(task: RobloxTaskState) -> RoutePlan:
+    valid, reasons = validate_deterministic_parameters(task.user_objective, selected_instances=task.selected_instances)
+    if not valid:
+        raise ValueError("; ".join(reasons))
+    return RoutePlan(
+        deterministic=True,
+        model_id="",
+        engine_ids=("studio_bridge",),
+        sandbox_level=SandboxLevel.PREVIEW if task.operation_class in {"modify", "delete"} else SandboxLevel.NONE,
+        tool_ids=dynamic_tools(task.required_capabilities, task.risk_level),
+        reasons=("complete deterministic parameters", "model calls=0", "cloud calls=0"),
+    )
+
+
+def _model_role(task: RobloxTaskState) -> str:
+    values = set(task.task_classes)
+    if task.risk_level in {RiskLevel.R4, RiskLevel.R5}:
+        return "CLOUD_EXPERT"
+    if "cinematic_creation" in values:
+        return "CLOUD_VISION"
+    if values & {"facial_animation", "ui_validation", "multi_device_validation"}:
+        return "LOCAL_VISION_WORKER"
+    if values & {"script_creation", "script_patch", "script_refactor", "gameplay_system", "runtime_debugging", "security_review"}:
+        return "LOCAL_CODE_WORKER" if task.risk_level.value <= "R2" else "CLOUD_EXPERT"
+    if task.estimated_complexity < 0.25:
+        return "MICRO_ROUTER"
+    # Ordinary Roblox workflows remain local when a certified worker exists.
+    # Cloud Lite is reserved for explicit high-quality mode or certified local gaps.
+    if task.risk_level in {RiskLevel.R0, RiskLevel.R1, RiskLevel.R2, RiskLevel.R3}:
+        return "LOCAL_WORKER"
+    return "CLOUD_LITE"
+
+
+def route_task(
+    task: RobloxTaskState,
+    *,
+    graph: CapabilityGraph,
+    engines: EngineRegistry,
+    models: ModelRegistry,
+    certification: CertificationMatrix,
+    config: RobloxProfileConfig,
+    context: RoutingContext | None = None,
+    estimated_context_tokens: int = 1200,
+) -> tuple[RoutePlan, CapabilityResolution, tuple[EngineSpec, ...], ModelSpec | None]:
+    context = context or RoutingContext(user_quality_mode=config.mode)
+    if config.routing.prefer_deterministic and classify_deterministic_task(task.user_objective, selected_instances=task.selected_instances):
+        plan = deterministic_workflow(task)
+        resolution = graph.resolve(task.required_capabilities)
+        return plan, resolution, (), None
+
+    resolution = graph.resolve(task.required_capabilities)
+    if not resolution.supported:
+        raise EngineSelectionError(f"unsupported capability resolution: {resolution.missing or resolution.conflicts}")
+
+    sandbox = max((task.sandbox_level, resolution.sandbox_level), key=_sandbox_rank)
+    selected_engines = engines.select(
+        resolution.ordered,
+        required_sandbox=sandbox,
+        certification=certification,
+        minimum=CertificationLevel.VERIFIED,
+    )
+    role = _model_role(task)
+    cloud_role = role.startswith("CLOUD")
+    if cloud_role and (not config.cloud_enabled or context.cloud_requests_used >= config.max_cloud_requests_per_task):
+        role = "LOCAL_CODE_WORKER" if any(item.startswith("script_") for item in task.task_classes) else "LOCAL_WORKER"
+    require_vision = role in {"CLOUD_VISION", "LOCAL_VISION_WORKER"}
+    require_code = role in {"LOCAL_CODE_WORKER", "CLOUD_EXPERT"} and bool(set(task.task_classes) & {"script_creation", "script_patch", "script_refactor", "gameplay_system", "runtime_debugging", "security_review"})
+    minimum = CertificationLevel.CERTIFIED if task.risk_level in {RiskLevel.R4, RiskLevel.R5} or task.operation_class in {"create", "modify", "delete"} else CertificationLevel.VERIFIED
+    model = models.select(
+        role,
+        required_context=estimated_context_tokens,
+        require_vision=require_vision,
+        require_code=require_code,
+        require_tools=True,
+        require_structured=True,
+        prefer_local=config.routing.prefer_local and not cloud_role,
+        cloud_enabled=config.cloud_enabled,
+        minimum=minimum,
+    )
+    plan = RoutePlan(
+        deterministic=False,
+        model_id=model.model_id,
+        engine_ids=tuple(engine.engine_id for engine in selected_engines),
+        sandbox_level=sandbox,
+        tool_ids=dynamic_tools(resolution.ordered, task.risk_level),
+        reasons=(f"role={role}", f"risk={task.risk_level.value}", f"sandbox={sandbox.value}", f"cache_hit_rate={context.cache_hit_rate:.2f}"),
+    )
+    return plan, resolution, selected_engines, model
+
+
+def _sandbox_rank(value: SandboxLevel) -> int:
+    return {
+        SandboxLevel.NONE: 0,
+        SandboxLevel.PREVIEW: 1,
+        SandboxLevel.SHADOW_PROJECT: 2,
+        SandboxLevel.DIGITAL_TWIN: 3,
+        SandboxLevel.MIGRATION_LAB: 4,
+        SandboxLevel.EXTERNAL_SANDBOX: 5,
+    }[value]
