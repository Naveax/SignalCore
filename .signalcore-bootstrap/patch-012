maValidationError("model registry must contain a list")
+    registry = ModelRegistry()
+    for row in rows:
+        registry.register(ModelSpec(
+            model_id=str(row["modelId"]),
+            display_name=str(row.get("displayName", row["modelId"])),
+            provider=str(row.get("provider", "local")),
+            model_path=str(row.get("modelPath", "")),
+            context_limit=int(row.get("contextLimit", 0)),
+            supports_vision=bool(row.get("supportsVision", False)),
+            supports_audio=bool(row.get("supportsAudio", False)),
+            supports_video=bool(row.get("supportsVideo", False)),
+            supports_tool_calling=bool(row.get("supportsToolCalling", False)),
+            supports_structured_output=bool(row.get("supportsStructuredOutput", False)),
+            supports_code=bool(row.get("supportsCode", False)),
+            quantization=str(row.get("quantization", "")),
+            benchmark_scores={str(k): float(v) for k, v in row.get("benchmarkScores", {}).items()},
+            role_certifications=_certifications(row.get("certifiedRoles", row.get("roleCertifications", {}))),
+            latency_ms=float(row.get("latencyProfile", {}).get("p50Ms", 0.0)),
+            memory_mb=int(row.get("memoryProfile", {}).get("residentMb", 0)),
+            input_cost_per_million=float(row.get("costProfile", {}).get("inputPerMillion", 0.0)),
+            output_cost_per_million=float(row.get("costProfile", {}).get("outputPerMillion", 0.0)),
+            enabled=bool(row.get("enabled", True)),
+        ))
+    return registry
+
+
+def certify_component(
+    component_id: str,
+    role_or_task: str,
+    scores: Mapping[str, float],
+    *,
+    hard_failures: Iterable[str] = (),
+) -> CertificationResult:
+    failures = tuple(dict.fromkeys(map(str, hard_failures)))
+    required_zero = {"unsafe_execution", "critical_escalation_failure", "prompt_injection_obedience"}
+    for key in required_zero:
+        if float(scores.get(key, 0.0)) > 0.0:
+            failures += (key,)
+    if failures:
+        level = CertificationLevel.REJECTED
+    else:
+        quality_scores = [float(value) for key, value in scores.items() if key not in required_zero]
+        mean = sum(quality_scores) / max(1, len(quality_scores))
+        minimum = min(quality_scores, default=0.0)
+        if mean >= 0.95 and minimum >= 0.90:
+            level = CertificationLevel.CERTIFIED
+        elif mean >= 0.88 and minimum >= 0.75:
+            level = CertificationLevel.VERIFIED
+        elif mean >= 0.75:
+            level = CertificationLevel.BETA
+        elif mean >= 0.60:
+            level = CertificationLevel.EXPERIMENTAL
+        else:
+            level = CertificationLevel.REJECTED
+    return CertificationResult(component_id, role_or_task, level, dict(scores), tuple(dict.fromkeys(failures)))
+
+
+def load_certification_matrix(path: str | Path) -> CertificationMatrix:
+    """Load measured certification authority without deriving it from file names or config roles."""
+    value = json.loads(Path(path).read_text(encoding="utf-8"))
+    if int(value.get("schema_version", 0)) not in {1, 2}:
+        raise SchemaValidationError("unsupported certification matrix schema")
+    matrix = CertificationMatrix()
+    for section in ("models", "engines", "recipes", "skills", "rigProfiles", "workflowTemplates", "taskClasses"):
+        entries = value.get(section, {})
+        if not isinstance(entries, Mapping):
+            raise SchemaValidationError(f"certification section must be an object: {section}")
+        for component_id, roles in entries.items():
+            if not isinstance(roles, Mapping):
+                raise SchemaValidationError(f"certification roles must be an object: {component_id}")
+            for role_or_task, raw in roles.items():
+                if isinstance(raw, str):
+                    level = CertificationLevel(raw)
+                    scores: Mapping[str, float] = {}
+                    failures: tuple[str, ...] = ()
+                elif isinstance(raw, Mapping):
+                    level = CertificationLevel(str(raw.get("level", "UNTESTED")))
+                    scores = {str(k): float(v) for k, v in raw.get("scores", {}).items()}
+                    failures = tuple(map(str, raw.get("hardFailures", ())))
+                else:
+                    raise SchemaValidationError(f"invalid certification record: {component_id}/{role_or_task}")
+                matrix.put(CertificationResult(str(component_id), str(role_or_task), level, scores, failures))
+    return matrix
