diff --git a/.github/workflows/validate.yml b/.github/workflows/validate.yml
new file mode 100644
index 0000000..d2aa7d7
--- /dev/null
+++ b/.github/workflows/validate.yml
@@ -0,0 +1,36 @@
+name: Validate SignalCore
+
+on:
+  push:
+    branches: [main]
+  pull_request:
+  workflow_dispatch:
+
+permissions:
+  contents: read
+
+jobs:
+  validate:
+    strategy:
+      fail-fast: false
+      matrix:
+        os: [ubuntu-latest, windows-latest, macos-latest]
+        python-version: ['3.11', '3.12', '3.13']
+    runs-on: ${{ matrix.os }}
+    steps:
+      - uses: actions/checkout@v4
+      - uses: actions/setup-python@v5
+        with:
+          python-version: ${{ matrix.python-version }}
+      - name: Compile
+        run: python -m compileall -q skills/signal-core/scripts skills/signal-core/profiles tools tests benchmarks
+      - name: Validate package
+        run: python tools/validate.py
+      - name: Run all tests
+        run: python -m unittest discover -s tests -q
+      - name: Roblox orchestration smoke benchmark
+        run: python benchmarks/roblox_profile_benchmark.py --cases 50 --output roblox-profile-smoke.json
+      - name: Check platform registry
+        run: python tools/install.py list --output platform-registry.json
+      - name: Dry-run native adapters
+        run: python tools/install.py install --platforms all-native --scope project --project . --dry-run --output native-dry-run.json
