+class ModelRegistry:
+    def __init__(self, models: Iterable[ModelSpec] = ()) -> None:
+        self.models = {model.model_id: model for model in models}
+
+    def register(self, model: ModelSpec) -> None:
+        if model.context_limit <= 0:
+            raise SchemaValidationError("model context limit must be positive")
+        self.models[model.model_id] = model
+
+    def select(
+        self,
+        role: str,
+        *,
+        required_context: int,
+        require_vision: bool = False,
+        require_code: bool = False,
+        require_tools: bool = False,
+        require_structured: bool = True,
+        prefer_local: bool = True,
+        cloud_enabled: bool = True,
+        minimum: CertificationLevel = CertificationLevel.VERIFIED,
+        maximum_input_cost: float | None = None,
+    ) -> ModelSpec:
+        candidates: list[ModelSpec] = []
+        for model in self.models.values():
+            if not model.enabled or model.context_limit < required_context:
+                continue
+            if require_vision and not model.supports_vision:
+                continue
+            if require_code and not model.supports_code:
+                continue
+            if require_tools and not model.supports_tool_calling:
+                continue
+            if require_structured and not model.supports_structured_output:
+                continue
+            if not cloud_enabled and model.provider not in {"llama.cpp", "ollama", "lmstudio", "local"}:
+                continue
+            if maximum_input_cost is not None and model.input_cost_per_million > maximum_input_cost:
+                continue
+            level = model.role_certifications.get(role, CertificationLevel.UNTESTED)
+            if isinstance(level, str):
+                level = CertificationLevel(level)
+            if level == CertificationLevel.REJECTED or level.authority < minimum.authority:
+                continue
+            candidates.append(model)
+        if not candidates:
+            raise ModelSelectionError(f"no certified model for role {role}")
+
+        def score(item: ModelSpec) -> tuple[float, float, float, str]:
+            local = item.provider in {"llama.cpp", "ollama", "lmstudio", "local"}
+            local_penalty = 0.0 if local == prefer_local else 1.0
+            quality = float(item.benchmark_scores.get(role, item.benchmark_scores.get("overall", 0.0)))
+            cost = item.input_cost_per_million + item.output_cost_per_million
+            return (local_penalty, -quality, item.latency_ms + cost * 100.0, item.model_id)
+
+        return min(candidates, key=score)
+
