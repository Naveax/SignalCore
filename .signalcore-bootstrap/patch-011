+                tools=route.tool_ids,
+                project_summary=project_summary,
+            )
+            cloud = selected_model is not None and selected_model.provider not in {"local", "llama.cpp", "ollama", "lmstudio"}
+            budget.reserve(
+                cloud_requests=1 if cloud else 0,
+                cloud_expert_tokens=capsule.total_tokens if cloud and task.estimated_cloud_need == "REQUIRED" else 0,
+                cloud_lite_tokens=capsule.total_tokens if cloud and task.estimated_cloud_need != "REQUIRED" else 0,
+                local_tokens=capsule.total_tokens if not cloud else 0,
+                transfer_units=capsule.total_transfer_cost,
+            )
+        validators_by_capability = {
+            capability: self.graph.get(capability).required_validators for capability in resolution.ordered
+        }
+        workflow = self.planner.plan(task, route, validators_by_capability=validators_by_capability)
+        compiler = compile_one_round_trip(task, capsule, workflow)
+        trace = make_trace(
+            task_state=task.to_dict(),
+            capability_resolution=asdict(resolution),
+            engine_selection={"engines": [engine.engine_id for engine in selected_engines]},
+            model_selection={"model": selected_model.model_id if selected_model else ""},
+            evidence_selection=[item.evidence_id for item in capsule.evidence],
+            context_capsule=asdict(capsule),
+            tool_schemas=route.tool_ids,
+            workflow=asdict(workflow),
+            budgets=budget.snapshot(),
+            tests=required_cross_validators(resolution.ordered),
+            repairs=(), commits=(), rollbacks=(),
+            versions={
+                "profile_schema": str(self.config.schema_version),
+                "capability_graph": self.graph.version,
+                **{f"engine:{engine.engine_id}": engine.version for engine in selected_engines},
+                **({f"model:{selected_model.model_id}": selected_model.quantization or selected_model.model_path or "configured"} if selected_model else {}),
+            },
+        )
+        self.telemetry_store.record_trace(trace)
+        cloud = selected_model is not None and selected_model.provider not in {"local", "llama.cpp", "ollama", "lmstudio"}
+        telemetry = TelemetryRecord(
+            task_id=task.task_id,
+            task_class=task.task_classes[0],
+            risk_level=task.risk_level,
+            workflow_nodes=len(workflow.nodes),
+            models_used=(selected_model.model_id,) if selected_model else (),
+            engines_used=tuple(engine.engine_id for engine in selected_engines),
+            cloud_requests=1 if cloud else 0,
+            local_requests=0 if cloud or selected_model is None else 1,
+            cloud_input_tokens=capsule.total_tokens if cloud else 0,
+            cloud_output_tokens=0,
+            local_tokens=capsule.total_tokens if not cloud else 0,
+            gpu_time_ms=0,
+            playtest_time_ms=0,
+            blender_time_ms=0,
+            context_candidates=len(evidence_candidates),
+            context_selected=len(capsule.evidence),
+            cache_hit_rate=(routing_context.cache_hit_rate if routing_context else 0.0),
+            repair_count=0,
+            rollback_count=0,
+            wall_time_ms=int((time.perf_counter() - started) * 1000),
+            verified=False,
+            final_status=FinalStatus.COMPLETED_WITH_WARNINGS,
+        )
+        self.telemetry_store.record(telemetry)
+        return OrchestrationResult(task, gate, route, capsule, workflow, compiler, trace, telemetry)
+
+
+def _blocked_status(status: str) -> FinalStatus:
+    mapping = {
+        "BLOCKED_AMBIGUOUS": FinalStatus.BLOCKED_AMBIGUOUS,
+        "BLOCKED_UNSUPPORTED": FinalStatus.BLOCKED_UNSUPPORTED,
+        "BLOCKED_MISSING_ENGINE": FinalStatus.BLOCKED_UNSUPPORTED,
+        "BLOCKED_MISSING_EVIDENCE": FinalStatus.BLOCKED_UNSUPPORTED,
+        "BLOCKED_POLICY": FinalStatus.BLOCKED_POLICY,
+        "BLOCKED_BUDGET": FinalStatus.BLOCKED_BUDGET,
+    }
+    return mapping.get(status, FinalStatus.BLOCKED_POLICY)
