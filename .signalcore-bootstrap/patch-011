+@dataclass(frozen=True)
+class CertificationResult:
+    component_id: str
+    role_or_task: str
+    level: CertificationLevel
+    scores: Mapping[str, float]
+    hard_failures: tuple[str, ...] = ()
+
+    @property
+    def accepted(self) -> bool:
+        return not self.hard_failures and self.level.authority >= CertificationLevel.BETA.authority
+
+
+class CertificationMatrix:
+    def __init__(self, entries: Iterable[CertificationResult] = ()) -> None:
+        self._entries = {(item.component_id, item.role_or_task): item for item in entries}
+
+    def put(self, result: CertificationResult) -> None:
+        self._entries[(result.component_id, result.role_or_task)] = result
+
+    def level(self, component_id: str, role_or_task: str) -> CertificationLevel:
+        item = self._entries.get((component_id, role_or_task))
+        return item.level if item else CertificationLevel.UNTESTED
+
+    def require(self, component_id: str, role_or_task: str, minimum: CertificationLevel) -> bool:
+        level = self.level(component_id, role_or_task)
+        return level != CertificationLevel.REJECTED and level.authority >= minimum.authority
+
+    def to_dict(self) -> dict[str, dict[str, str]]:
+        output: dict[str, dict[str, str]] = {}
+        for (component, role), result in self._entries.items():
+            output.setdefault(component, {})[role] = result.level.value
+        return output
+
+
+class EngineRegistry:
+    def __init__(self, engines: Iterable[EngineSpec] = ()) -> None:
+        self.engines = {engine.engine_id: engine for engine in engines}
+
+    def register(self, engine: EngineSpec) -> None:
+        if not engine.version or engine.version.casefold() in {"latest", "*"}:
+            raise SchemaValidationError("engine versions must be pinned")
+        self.engines[engine.engine_id] = engine
+
+    def select(
+        self,
+        capabilities: Iterable[str],
+        *,
+        required_sandbox: SandboxLevel,
+        certification: CertificationMatrix,
+        minimum: CertificationLevel = CertificationLevel.VERIFIED,
+    ) -> tuple[EngineSpec, ...]:
+        selected: list[EngineSpec] = []
+        for capability in dict.fromkeys(capabilities):
+            candidates = [
+                engine for engine in self.engines.values()
+                if engine.enabled
+                and capability in engine.capabilities
+                and required_sandbox in engine.sandbox_support
+                and certification.require(engine.engine_id, capability, minimum)
+            ]
+            candidates.sort(key=lambda item: (item.latency_ms, item.gpu_mb, item.engine_id))
+            if not candidates:
+                raise EngineSelectionError(f"no certified engine for {capability} in {required_sandbox.value}")
+            chosen = candidates[0]
+            if chosen not in selected:
+                selected.append(chosen)
+        return tuple(selected)
+
+    def validate_invocation(self, engine_id: str, capability: str) -> None:
+        engine = self.engines.get(engine_id)
+        if engine is None or not engine.enabled:
+            raise EngineSelectionError(f"engine unavailable: {engine_id}")
+        if capability not in engine.capabilities:
+            raise EngineSelectionError(f"engine {engine_id} does not declare {capability}")
