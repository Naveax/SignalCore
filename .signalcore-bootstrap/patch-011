f not gate.execution_allowed or route is None:
+            status = _blocked_status(gate.status.value)
+            telemetry = TelemetryRecord(
+                task.task_id, task.task_classes[0], task.risk_level, 0, (), (), 0, 0, 0, 0, 0, 0, 0, 0,
+                len(evidence_candidates), 0, 0.0, 0, 0, int((time.perf_counter() - started) * 1000), False, status,
+            )
+            self.telemetry_store.record(telemetry)
+            return OrchestrationResult(task, gate, route, None, None, None, None, telemetry)
+
+        if route.deterministic:
+            capsule = ContextCapsule(task.to_dict(), dict(project_summary or {}), (), (), (), task.acceptance_criteria, route.tool_ids, 0, 0)
+        else:
+            token_budget = self.config.budgets.cloud_expert_tokens if task.estimated_cloud_need == "REQUIRED" else self.config.budgets.cloud_lite_tokens
+            capsule = self.knapsack.capsule(
+                task,
+                evidence_candidates,
