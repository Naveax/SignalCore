+from __future__ import annotations
+
+import json
+from dataclasses import dataclass, field
+from pathlib import Path
+from typing import Any, Mapping
+
+from .types import RiskLevel, SandboxLevel
+
+
+MODEL_ROLES = (
+    "MICRO_ROUTER", "TASK_COMPILER", "LOCAL_WORKER", "LOCAL_CODE_WORKER",
+    "LOCAL_VISION_WORKER", "CLOUD_LITE", "CLOUD_EXPERT", "CLOUD_VISION", "CLOUD_REVIEWER",
+)
+
+
+@dataclass(frozen=True)
+class RoutingPolicy:
+    prefer_deterministic: bool = True
+    prefer_local: bool = True
+    prefer_small: bool = True
+    allow_cloud: bool = True
+    max_repair_attempts: int = 2
+    confidence_threshold: float = .8
+    high_risk_threshold: RiskLevel = RiskLevel.R4
+
+
+@dataclass(frozen=True)
+class BudgetPolicy:
+    input_tokens: int = 32768
+    output_tokens: int = 8192
+    thinking_tokens: int = 16384
+    cloud_requests: int = 2
+    local_requests: int = 4
+    retries: int = 2
+    wall_time_seconds: int = 900
+    gpu_time_seconds: int = 300
+    transfer_bytes: int = 100 * 1024 * 1024
+
+
+@dataclass(frozen=True)
+class RetentionPolicy:
+    session_seconds: int = 86400
+    project_seconds: int = 30 * 86400
+    certification_seconds: int = 365 * 86400
+    temporary_media_seconds: int = 3600
+    do_not_retain_by_default: bool = True
+
+
+DEFAULT_CONTEXT_BUDGETS = {
+    "MICRO_ROUTER": 768,
+    "TASK_COMPILER": 4096,
+    "LOCAL_WORKER": 8192,
+    "LOCAL_CODE_WORKER": 12288,
+    "LOCAL_VISION_WORKER": 4096,
+    "CLOUD_LITE": 12288,
+    "CLOUD_EXPERT": 32768,
+    "CLOUD_VISION": 12288,
+    "CLOUD_REVIEWER": 8192,
+}
+
+
+@dataclass(frozen=True)
+class RobloxProfileConfig:
+    schema_version: int = 2
+    routing: RoutingPolicy = field(default_factory=RoutingPolicy)
+    budgets: BudgetPolicy = field(default_factory=BudgetPolicy)
+    retention: RetentionPolicy = field(default_factory=RetentionPolicy)
+    context_budgets: Mapping[str, int] = field(default_factory=lambda: dict(DEFAULT_CONTEXT_BUDGETS))
+    sandbox_availability: frozenset[SandboxLevel] = frozenset({
+        SandboxLevel.NONE, SandboxLevel.PREVIEW, SandboxLevel.SHADOW_PROJECT,
+        SandboxLevel.DIGITAL_TWIN, SandboxLevel.MIGRATION_LAB, SandboxLevel.EXTERNAL_SANDBOX,
+    })
+    enabled_engines: frozenset[str] = frozenset()
+    enabled_models: frozenset[str] = frozenset()
+    full_project_cloud_upload: bool = False
+    adaptive_learning_enabled: bool = False
+    metadata: Mapping[str, object] = field(default_factory=dict)
+
+    def validate(self) -> None:
+        if self.schema_version != 2:
+            raise ValueError("unsupported Roblox profile config schema")
+        if self.full_project_cloud_upload:
+            raise ValueError("full-project cloud upload is forbidden")
+        if self.routing.max_repair_attempts < 0 or self.routing.max_repair_attempts > 4:
+            raise ValueError("repair attempts must be between zero and four")
+        if not 0.0 <= self.routing.confidence_threshold <= 1.0:
+            raise ValueError("confidence threshold must be within [0, 1]")
+        if any(int(value) <= 0 for value in self.context_budgets.values()):
+            raise ValueError("context budgets must be positive")
+
+
+def _require_mapping(value: Any, name: str) -> Mapping[str, Any]:
+    if not isinstance(value, Mapping):
+        raise ValueError(f"{name} must be a mapping")
+    return value
+
+
+def load_config(path: str | Path) -> RobloxProfileConfig:
+    payload = json.loads(Path(path).read_text(encoding="utf-8"))
+    if not isinstance(payload, dict):
+        raise ValueError("config root must be an object")
+    routing_raw = _require_mapping(payload.get("routing", {}), "routing")
+    budgets_raw = _require_mapping(payload.get("budgets", {}), "budgets")
+    retention_raw = _require_mapping(payload.get("retention", {}), "retention")
+    context_raw = _require_mapping(payload.get("contextBudgets", DEFAULT_CONTEXT_BUDGETS), "contextBudgets")
+    routing = RoutingPolicy(
+        prefer_deterministic=bool(routing_raw.get("preferDeterministic", True)),
+        prefer_local=bool(routing_raw.get("preferLocal", True)),
+        prefer_small=bool(routing_raw.get("preferSmall", True)),
+        allow_cloud=bool(routing_raw.get("allowCloud", True)),
+        max_repair_attempts=int(routing_raw.get("maxRepairAttempts", 2)),
+        confidence_threshold=float(routing_raw.get("confidenceThreshold", .8)),
+        high_risk_threshold=RiskLevel(str(routing_raw.get("highRiskThreshold", "R4"))),
+    )
+    budgets = BudgetPolicy(
+        input_tokens=int(budgets_raw.get("inputTokens", 32768)),
+        output_tokens=int(budgets_raw.get("outputTokens", 8192)),
+        thinking_tokens=int(budgets_raw.get("thinkingTokens", 16384)),
+        cloud_requests=int(budgets_raw.get("cloudRequests", 2)),
+        local_requests=int(budgets_raw.get("localRequests", 4)),
+        retries=int(budgets_raw.get("retries", 2)),
+        wall_time_seconds=int(budgets_raw.get("wallTimeSeconds", 900)),
+        gpu_time_seconds=int(budgets_raw.get("gpuTimeSeconds", 300)),
+        transfer_bytes=int(budgets_raw.get("transferBytes", 100 * 1024 * 1024)),
+    )
+    retention = RetentionPolicy(
+        session_seconds=int(retention_raw.get("sessionSeconds", 86400)),
+        project_seconds=int(retention_raw.get("projectSeconds", 30 * 86400)),
+        certification_seconds=int(retention_raw.get("certificationSeconds", 365 * 86400)),
+        temporary_media_seconds=int(retention_raw.get("temporaryMediaSeconds", 3600)),
+        do_not_retain_by_default=bool(retention_raw.get("doNotRetainByDefault", True)),
+    )
+    config = RobloxProfileConfig(
+        schema_version=int(payload.get("schema_version", 2)),
+        routing=routing,
+        budgets=budgets,
+        retention=retention,
+        context_budgets={str(key): int(value) for key, value in context_raw.items()},
+        sandbox_availability=frozenset(SandboxLevel(str(item)) for item in payload.get("sandboxAvailability", [item.value for item in SandboxLevel])),
+        enabled_engines=frozenset(map(str, payload.get("enabledEngines", []))),
+        enabled_models=frozenset(map(str, payload.get("enabledModels", []))),
+        full_project_cloud_upload=bool(payload.get("fullProjectCloudUpload", False)),
+        adaptive_learning_enabled=bool(payload.get("adaptiveLearningEnabled", False)),
+        metadata=dict(payload.get("metadata", {})),
+    )
+    config.validate()
+    return config
