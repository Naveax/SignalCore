+                CREATE TABLE IF NOT EXISTS compression_chunks(
+                    compression_id TEXT NOT NULL,
+                    chunk_index INTEGER NOT NULL,
+                    chunk_handle TEXT NOT NULL,
+                    chunk_bytes INTEGER NOT NULL,
+                    PRIMARY KEY(compression_id,chunk_index),
