+        return self._bounded(self._redact("\n\n---\n\n".join(selected)), budget_bytes), {"blocks": len(blocks), "selected": len(selected)}
+
+    def _compress_text(self, text: str, *, budget_bytes: int, path: str) -> tuple[str, dict[str, Any]]:
