+def _contextualize_validator_error(exc, attr, path):
+    """Add an item path to a nested validation error in place."""
+    previous_path = getattr(exc, "_attrs_validation_path", attr.name)
+    previous_attr = getattr(exc, "_attrs_validation_attribute", attr)
+    suffix = (
+        previous_path[len(attr.name) :]
+        if previous_path.startswith(attr.name)
+        else ""
+    )
+    full_path = f"{path}{suffix}"
+    path_attr = attr.evolve(name=full_path)
+    old_single = f"'{previous_path}'"
+    new_single = f"'{full_path}'"
+    old_double = f'"{previous_path}"'
+    new_double = f'"{full_path}"'
+
+    def contextualize(part):
+        if part is attr or part is previous_attr:
+            return path_attr
+        if isinstance(part, str):
+            return part.replace(old_single, new_single).replace(
+                old_double, new_double
+            )
+        return part
+
+    exc.args = tuple(contextualize(part) for part in exc.args)
+    if isinstance(getattr(exc, "msg", None), str):
+        try:
+            exc.msg = contextualize(exc.msg)
+        except AttributeError:
+            pass
+    try:
+        exc._attrs_validation_path = full_path
+        exc._attrs_validation_attribute = path_attr
+    except AttributeError:
+        pass
+
+
+def _format_mapping_key(key):
+    """Render mapping keys unambiguously inside an attribute path."""
+    if isinstance(key, str):
+        return json.dumps(key, ensure_ascii=False)
+    return repr(key)
+
+
